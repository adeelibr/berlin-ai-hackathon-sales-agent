# Client-side Supabase configuration required for app startup.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side Supabase configuration required for SSR and backend routes.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Preferred elevated backend key for server-only Supabase access.
SUPABASE_SECRET_KEY=

# Required for conversation TTS/STT features.
GRADIUM_API_KEY=

# Required for conversation replies and sales report generation.
OPENAI_API_KEY=

# Optional override for the OpenAI model used for replies and reports.
OPENAI_MODEL=gpt-4o-mini

# Global call transport configuration.
# Set CALL_TRANSPORT_MODE to "twilio" or "dummy".
CALL_TRANSPORT_MODE=dummy

# Fixed target number used by the current outbound workflow.
# In dummy mode this must match the number opened at /phone-dummy/<number>.
CALL_TARGET_NUMBER=

# Base URL of the standalone dummy phone media service.
# Example: http://localhost:8788
DUMMY_PHONE_SERVICE_URL=

# Optional label shown on the dummy phone incoming call screen.
DUMMY_PHONE_CALLER_LABEL=Stillwater Demo

# Optional port for the standalone dummy phone media service.
DUMMY_PHONE_MEDIA_PORT=8788

# Required for outbound Twilio phone calls and Twilio request validation when
# CALL_TRANSPORT_MODE=twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public HTTPS base URL for app callbacks and public handset URLs.
# For local development this should be your tunnel URL.
PUBLIC_BASE_URL=
