# Client-side Supabase configuration required for app startup.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side Supabase configuration required for SSR and backend routes.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Preferred elevated backend key for server-only Supabase access.
SUPABASE_SECRET_KEY=

# Required for conversation TTS/STT features.
GRADIUM_API_KEY=

# Required for conversation replies and sales report generation.
GEMINI_API_KEY=

# Required for outbound Twilio phone calls and Twilio request validation.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Public HTTPS base URL for Twilio callbacks; the media stream URL is derived as WSS.
# For local development this should be your tunnel URL.
PUBLIC_BASE_URL=
